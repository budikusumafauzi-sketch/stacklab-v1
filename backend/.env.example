# StackLab Backend Environment Variables Example
# Do not place any actual secrets in this file!

# Project configuration
PROJECT_NAME="StackLab API"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# CORS configuration
# A comma-separated list of allowed origins
BACKEND_CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Database Configuration (Placeholder)
DATABASE_URL="postgresql://user:password@localhost:5432/stacklab"

# Security (Generate a secure key for production)
SECRET_KEY="replace-with-a-very-secret-key-for-development"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
